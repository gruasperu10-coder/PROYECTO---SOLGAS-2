rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: pickups
    // Document ID: auto-generated
    // Fields:
    //   - senderName: string (required)
    //   - receiverName: string (required)
    //   - itemDescription: string (required)
    //   - signatureData: string (required, base64)
    //   - timestamp: timestamp (required)
    //   - createdBy: string (required, uid)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidRecord(data) {
      let validRooms = ["Solgas Hogar", "Solgas Energia", "Auma", "Espiritu Integro", "Espiritu Colaborativo", "Espiritu Agil", "Espiritu Innovador"];
      let validTypes = ["retiro", "devolucion"];
      
      return data.keys().hasAll(['personName', 'eventTime', 'roomName', 'type', 'signatureData', 'timestamp']) &&
             data.personName is string && data.personName.size() > 0 && data.personName.size() < 100 &&
             data.eventTime is string && data.eventTime.size() > 0 &&
             data.roomName in validRooms &&
             data.type in validTypes &&
             data.signatureData is string && data.signatureData.size() > 0 &&
             data.timestamp is timestamp;
    }

    match /records/{recordId} {
      allow read: if true;
      allow create: if isValidRecord(request.resource.data);
      allow update, delete: if false;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
